{
  "manifest_version": 3,
  "name": "Lick to Anki",
  "version": "1.0",
  "description": "Capture YouTube phrases as Anki cards for guitar practice",
  "permissions": ["activeTab", "storage", "nativeMessaging", "scripting"],
  "host_permissions": ["*://*.youtube.com/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["panel.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
